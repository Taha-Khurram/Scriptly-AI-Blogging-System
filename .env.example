# ScriptlyAI environment variables
# Copy to `.env` for local dev, or set these in the Render dashboard for deploy.
# Do NOT commit real values — `.env` is gitignored.

# --- Flask ---
FLASK_APP=main.py
FLASK_ENV=production
# 1 = local auto-reload dev server, 0 = production
FLASK_DEBUG=1
SECRET_KEY=change-me-to-a-long-random-string

# --- Firebase Admin (server) ---
# Either an absolute path to the service-account file, OR the full JSON as a
# single-line string. On Render, paste the raw JSON string.
FIREBASE_SERVICE_ACCOUNT=serviceAccountKey.json

# --- Firebase Web SDK (client config) ---
FB_API_KEY=
FB_AUTH_DOMAIN=
FB_PROJECT_ID=
FB_STORAGE_BUCKET=
FB_SENDER_ID=
FB_APP_ID=
FB_MEASUREMENT_ID=

# --- AI ---
GEMINI_API_KEY=

# --- RapidAPI (SEO tools) ---
RAPIDAPI_KEY=
AHREFS_RAPIDAPI_KEY=
SITE_AUDIT_RAPIDAPI_KEY=

# --- Email (Gmail SMTP) ---
GMAIL_USER=
GMAIL_APP_PASSWORD=
FROM_NAME=ScriptlyAI

# --- Google OAuth (Analytics integration) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
